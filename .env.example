# Server
PORT=8787
AUTH_MODE=supabase
DATA_BACKEND=supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME_SERVER_ONLY
MCP_API_KEY=generate-a-long-random-secret
MCP_OWNER_ID=replace-with-auth-user-uuid
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Client (copy these into apps/client/.env)
EXPO_PUBLIC_API_URL=https://YOUR-API-DOMAIN.example.com
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
